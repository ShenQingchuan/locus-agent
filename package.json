{
  "name": "locus-agent-monorepo",
  "type": "module",
  "version": "0.1.4",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShenQingchuan/locus-agent"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "pnpm -F @univedge/locus-server dev",
    "dev:web": "pnpm -F @univedge/locus-web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm -F @univedge/locus-server db:generate",
    "db:migrate": "pnpm -F @univedge/locus-server db:migrate",
    "db:studio": "pnpm -F @univedge/locus-server db:studio",
    "reexport:chains": "node scripts/find-reexport-chains.mjs",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev-tools",
    "@types/node": "catalog:dev-tools",
    "eslint": "catalog:dev-tools",
    "git-cliff": "catalog:cli-tools",
    "typescript": "catalog:dev-tools"
  }
}
