{
  "name": "@univedge/locus-cli",
  "type": "module",
  "version": "0.1.0",
  "description": "Locus Agent CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShenQingchuan/locus-agent",
    "directory": "apps/cli"
  },
  "bin": {
    "locus": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:cli-tools",
    "@univedge/locus-agent-sdk": "workspace:*",
    "@univedge/locus-server": "workspace:*",
    "hono": "catalog:hono-family"
  },
  "devDependencies": {
    "@types/bun": "catalog:bun-family",
    "typescript": "catalog:dev-tools"
  }
}
