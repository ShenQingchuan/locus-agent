{
  "name": "@locus-agent/server",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "bun": "./src/db/index.ts",
      "dev": "./src/db/index.ts",
      "default": "./dist/db/index.js"
    },
    "./config": {
      "bun": "./src/config.ts",
      "dev": "./src/config.ts",
      "default": "./dist/config.js"
    },
    "./providers": {
      "bun": "./src/agent/providers/index.ts",
      "dev": "./src/agent/providers/index.ts",
      "default": "./dist/agent/providers/index.js"
    },
    "./settings": {
      "bun": "./src/settings/index.ts",
      "dev": "./src/settings/index.ts",
      "default": "./dist/settings/index.js"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:ai-sdk",
    "@ai-sdk/moonshotai": "catalog:ai-sdk",
    "@ai-sdk/openai": "catalog:ai-sdk",
    "@ai-sdk/openai-compatible": "^2.0.27",
    "@locus-agent/shared": "workspace:*",
    "ai": "catalog:ai-sdk",
    "diff": "catalog:ai-sdk",
    "drizzle-orm": "catalog:database",
    "hono": "catalog:hono-family",
    "zod": "catalog:ai-sdk"
  },
  "devDependencies": {
    "@types/bun": "catalog:bun-family",
    "drizzle-kit": "catalog:database",
    "typescript": "catalog:dev-tools"
  }
}
