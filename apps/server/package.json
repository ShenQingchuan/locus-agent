{
  "name": "@univedge/locus-server",
  "type": "module",
  "version": "0.2.2",
  "private": true,
  "description": "Backend server for Locus Agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShenQingchuan/locus-agent",
    "directory": "apps/server"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "bun": "./src/db/index.ts",
      "dev": "./src/db/index.ts",
      "default": "./dist/db/index.js"
    },
    "./config": {
      "bun": "./src/config.ts",
      "dev": "./src/config.ts",
      "default": "./dist/config.js"
    },
    "./providers": {
      "bun": "./src/agent/providers/index.ts",
      "dev": "./src/agent/providers/index.ts",
      "default": "./dist/agent/providers/index.js"
    },
    "./settings": {
      "bun": "./src/settings/index.ts",
      "dev": "./src/settings/index.ts",
      "default": "./dist/settings/index.js"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run build.ts",
    "typecheck": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@a2a-js/sdk": "catalog:ai-sdk",
    "@agentclientprotocol/claude-agent-acp": "catalog:ai-sdk",
    "@agentclientprotocol/sdk": "catalog:ai-sdk",
    "@ai-sdk/anthropic": "catalog:ai-sdk",
    "@ai-sdk/deepseek": "catalog:ai-sdk",
    "@ai-sdk/mcp": "catalog:ai-sdk",
    "@ai-sdk/moonshotai": "catalog:ai-sdk",
    "@ai-sdk/openai": "catalog:ai-sdk",
    "@ai-sdk/openai-compatible": "catalog:ai-sdk",
    "@huggingface/transformers": "catalog:embedding",
    "@openrouter/ai-sdk-provider": "catalog:ai-sdk",
    "@univedge/locus-agent-sdk": "workspace:*",
    "@univedge/locus-plugin-kit": "workspace:*",
    "ai": "catalog:ai-sdk",
    "consola": "catalog:cli-tools",
    "drizzle-orm": "catalog:database",
    "hono": "catalog:hono-family",
    "ignore": "catalog:fs-utils",
    "sqlite-vec": "catalog:embedding",
    "zhipu-ai-provider": "catalog:ai-sdk",
    "zod": "catalog:ai-sdk"
  },
  "optionalDependencies": {
    "onnxruntime-node": "catalog:embedding"
  },
  "devDependencies": {
    "@types/bun": "catalog:bun-family",
    "@typescript/native-preview": "catalog:dev-tools",
    "drizzle-kit": "catalog:database",
    "typescript": "catalog:dev-tools"
  }
}
