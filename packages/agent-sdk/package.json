{
  "name": "@univedge/locus-agent-sdk",
  "type": "module",
  "version": "0.2.0",
  "description": "Shared SDK for Locus Agent — runtime contracts, hook events, plugin system, SSE protocol, and prompt utilities.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShenQingchuan/locus-agent",
    "directory": "packages/agent-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tool-helper": {
      "bun": "./src/tool-helper.ts",
      "dev": "./src/tool-helper.ts",
      "types": "./dist/tool-helper.d.ts",
      "default": "./dist/tool-helper.js"
    },
    "./session": {
      "bun": "./src/session.ts",
      "dev": "./src/session.ts",
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./agent": {
      "bun": "./src/agent.ts",
      "dev": "./src/agent.ts",
      "types": "./dist/agent.d.ts",
      "default": "./dist/agent.js"
    },
    "./mcp": {
      "bun": "./src/mcp/index.ts",
      "dev": "./src/mcp/index.ts",
      "types": "./dist/mcp/index.d.ts",
      "default": "./dist/mcp/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    ".cursor",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "catalog:ai-sdk",
    "zod": "catalog:ai-sdk"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "catalog:ai-sdk",
    "@types/node": "catalog:dev-tools",
    "@typescript/native-preview": "catalog:dev-tools",
    "tsdown": "catalog:dev-tools",
    "zod": "catalog:ai-sdk"
  }
}
