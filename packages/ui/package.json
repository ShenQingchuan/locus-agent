{
  "name": "@univedge/locus-ui",
  "type": "module",
  "version": "0.1.3",
  "private": true,
  "description": "Shared Vue 3 UI components for Locus Agent.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShenQingchuan/locus-agent",
    "directory": "packages/ui"
  },
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/vue-virtual": "^3.0.0",
    "@vueuse/core": "^14.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tanstack/vue-virtual": "catalog:vue-family",
    "@vue/tsconfig": "catalog:vue-family",
    "@vueuse/core": "catalog:vue-family",
    "typescript": "catalog:dev-tools",
    "vue": "catalog:vue-family",
    "vue-tsc": "catalog:vue-family"
  }
}
